					<font fontName="Angsana New" size="18" isBold="true"/>
				</textElement>
				<text><![CDATA[รายงานทะเบียนรับหนังสือ]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="69fbf99b-be22-4154-b332-129c2b51a490" x="0" y="26" width="822" height="26"/>
